# Ignore patterns for Node.js projects

# Dependencies
node_modules/
npm-debug.log
yarn-error.log
package-lock.json
yarn.lock

# Environment variables
.env
.env.local
.env.*.local

# IDE and editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# Build and dist
dist/
build/
*.tsbuildinfo

# Logs
logs/
*.log

# Temporary files
tmp/
temp/
*.tmp

# OS specific
Thumbs.db
.DS_Store
.AppleDouble
.LSOverride

# Project specific
config.local.ts
config.local.js
server-logs/
backups/
test-projects/
*.pem
*.key

# Database
*.db
*.sqlite
*.sqlite3

# Duplicator backups (don't commit actual backups)
duplicator_*.zip
duplicator_*.daf
installer.php (in root only)
